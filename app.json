{
  "expo": {
    "name": "Easacc React Native Learning",
    "slug": "easacc-react-native-learning",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "easacclearning",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSBluetoothAlwaysUsageDescription": "This app scans nearby Bluetooth devices so the user can select a network device."
      }
    },
    "android": {
      "permissions": [
        "BLUETOOTH",
        "BLUETOOTH_ADMIN",
        "BLUETOOTH_SCAN",
        "BLUETOOTH_CONNECT",
        "ACCESS_FINE_LOCATION"
      ],
      "adaptiveIcon": {
        "backgroundColor": "#176d8f"
      },
      "package": "com.anonymous.easaccreactnativelearning"
    },
    "web": {
      "bundler": "metro"
    }
  }
}

